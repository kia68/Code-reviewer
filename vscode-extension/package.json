{
  "name": "code-reviewer-vscode",
  "displayName": "Code Reviewer",
  "description": "Trigger automated code reviews (static analysis + LLM) from VS Code.",
  "version": "0.0.1",
  "private": true,
  "publisher": "ude-code-reviewer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReviewer.startReview",
        "title": "Code Reviewer: Review starten"
      }
    ],
    "configuration": {
      "title": "Code Reviewer",
      "properties": {
        "codeReviewer.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Basis-URL des Code-Reviewer-Backends."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}